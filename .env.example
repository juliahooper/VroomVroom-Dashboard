# Copy this file to .env and fill in your values. Never commit .env (it is in .gitignore).
# Get a YouTube Data API v3 key from Google Cloud Console if you need /youtube/vroom-vroom.

YOUTUBE_API_KEY=
# Optional: override the default video (Charli XCX – Vroom Vroom).
# YOUTUBE_VIDEO_ID=qfAqtFuGjWM

# PostgreSQL on our VM. When set, the app uses this instead of data/vroomvroom.db.
# See docs/DATABASE_CLOUD.md. Example (app and Postgres on same VM):
# DATABASE_URL=postgresql://vroomvroom:yourpassword@localhost:5432/vroomvroom
